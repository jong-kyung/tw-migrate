{
  "name": "tw-migrate",
  "version": "0.0.0",
  "description": "Preview and migrate React CSS to Tailwind utilities",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "tw-migrate": "bin/tw-migrate.js"
  },
  "files": [
    "bin",
    "html.js",
    "index.js",
    "index.d.ts",
    "native.js",
    "rfcs",
    "style-compiler.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "napi build --manifest-path crates/tw_migrate/Cargo.toml --package-json-path package.json --output-dir . --platform --release --no-js --dts binding.d.ts",
    "build:debug": "napi build --manifest-path crates/tw_migrate/Cargo.toml --package-json-path package.json --output-dir . --platform --no-js --dts binding.d.ts",
    "artifacts": "napi artifacts --output-dir . --npm-dir npm",
    "test": "cargo test && pnpm build:debug && node --test",
    "test:rust": "cargo test"
  },
  "napi": {
    "binaryName": "tw-migrate",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.3",
    "less": "4.7.0",
    "sass": "1.101.3",
    "tailwindcss": "4.3.3"
  },
  "optionalDependencies": {
    "tw-migrate-darwin-arm64": "workspace:0.0.0",
    "tw-migrate-darwin-x64": "workspace:0.0.0",
    "tw-migrate-linux-arm64-gnu": "workspace:0.0.0",
    "tw-migrate-linux-x64-gnu": "workspace:0.0.0",
    "tw-migrate-win32-x64-msvc": "workspace:0.0.0"
  },
  "dependencies": {
    "parse5": "7.3.0"
  }
}
