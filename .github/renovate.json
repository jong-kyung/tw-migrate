{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits", ":timezone(Asia/Seoul)"],
  "schedule": ["before 9am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 9am on monday"]
  },
  "packageRules": [
    {
      "groupName": "napi-rs",
      "matchPackageNames": ["napi", "napi-derive", "napi-build", "@napi-rs/cli"]
    },
    {
      "groupName": "oxc",
      "matchManagers": ["cargo"],
      "matchPackageNames": ["/^oxc/"]
    },
    {
      "groupName": "github-actions",
      "matchManagers": ["github-actions"]
    },
    {
      "groupName": "npm devDependencies (non-major)",
      "matchManagers": ["npm"],
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"]
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["cargo-major"]
    }
  ]
}
